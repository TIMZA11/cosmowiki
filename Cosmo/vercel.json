{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/index",    "destination": "/",        "permanent": true },
    { "source": "/index.html","destination": "/",       "permanent": true },
    { "source": "/orbit.html","destination": "/orbit",  "permanent": true },
    { "source": "/spacex.html","destination": "/spacex","permanent": true },
    { "source": "/category.html","destination": "/category","permanent": true },
    { "source": "/object.html","destination": "/object", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=2592000" }
      ]
    }
  ]
}
